# ─── DATABASE SETTINGS ──────────────────────────────────────
# PostgreSQL connection string for Prisma and the API
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shadow_litter?schema=public"

# ─── ORBITAL DATA SOURCES ───────────────────────────────────
# Sentinel-2 / Copernicus API Credentials (if required by custom downloader)
SENTINEL_HUB_CLIENT_ID=""
SENTINEL_HUB_CLIENT_SECRET=""

# ─── MUNICIPAL SYSTEM INTEGRATION ───────────────────────────
# Madurai Corporation API Endpoints (Staging/Production)
MADURAI_CORP_API_URL="https://api.maduraicorp.gov.in/v1"
MUNICIPAL_AUTH_TOKEN=""

# ─── SYSTEM CONFIGURATION ───────────────────────────────────
NODE_ENV="development"
PORT=3000
API_PORT=8000
DASHBOARD_PORT=8501

# ─── AI MODEL PARAMETERS ────────────────────────────────────
# Threshold for orbital detection confidence (0.0 - 1.0)
DETECTION_THRESHOLD=0.75
MODEL_VERSION="v1.0-unified"
